{
  "info": {
    "_postman_id": "8f4c3e1f-4f2a-4c6f-9f21-2f8f5f1a0001",
    "name": "yu-gi-oh-deck-management",
    "description": "Colecao global para autenticar, montar deck, registrar jogador, criar desafio, consultar cartas e gerar proxy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "deck_id", "value": "" },
    { "key": "challenge_id", "value": "" },
    { "key": "target_user_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "card_id", "value": "" },
    { "key": "search_name", "value": "Blue-Eyes" }
  ],
  "item": [
    {
      "name": "auth-service",
      "item": [
        {
          "name": "register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"ash\",\n  \"email\": \"ash@example.com\",\n  \"password\": \"secret123\"\n}" },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('returns user data', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.username).to.eql('ash');",
                  "  pm.expect(body.email).to.eql('ash@example.com');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{auth-api}}/auth/register", "host": ["{{auth-api}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"ash\",\n  \"password\": \"secret123\"\n}" },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accessToken).to.be.a('string');",
                  "  pm.expect(body.refreshToken).to.be.a('string');",
                  "  pm.expect(body.tokenType).to.eql('Bearer');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{auth-api}}/auth/login", "host": ["{{auth-api}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns user info', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('userId');",
                  "  pm.expect(body).to.have.property('username');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{auth-api}}/auth/me", "host": ["{{auth-api}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "deck-service",
      "item": [
        {
          "name": "create deck",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dragon Deck\"\n}" },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns deck name', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.name).to.eql('Dragon Deck');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{deck-api}}/decks", "host": ["{{deck-api}}"], "path": ["decks"] }
          }
        },
        {
          "name": "add card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"cardId\": {{card_id}},\n  \"quantity\": 3,\n  \"zone\": \"MAIN\"\n}" },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns deck shape', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('mainDeckSize');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{deck-api}}/decks/{{deck_id}}/cards", "host": ["{{deck-api}}"], "path": ["decks", "{{deck_id}}", "cards"] }
          }
        }
      ]
    },
    {
      "name": "community-service",
      "item": [
        {
          "name": "register player",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Yugi\",\n  \"latitude\": -23.5505,\n  \"longitude\": -46.6333,\n  \"platforms\": [\"PC\", \"Mobile\"]\n}"
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns player data', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.displayName).to.eql('Yugi');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{community-api}}/players", "host": ["{{community-api}}"], "path": ["players"] }
          }
        },
        {
          "name": "send challenge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetId\": \"{{target_user_id}}\",\n  \"challengerDeckId\": {{deck_id}},\n  \"message\": \"duel agora\"\n}"
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('challenge pending', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('PENDING');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{community-api}}/challenges", "host": ["{{community-api}}"], "path": ["challenges"] }
          }
        },
        {
          "name": "accept challenge",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"ACCEPT\",\n  \"targetDeckId\": {{deck_id}}\n}" },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('returns duel id', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('duelId');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{community-api}}/challenges/{{challenge_id}}", "host": ["{{community-api}}"], "path": ["challenges", "{{challenge_id}}"] }
          }
        }
      ]
    },
    {
      "name": "card-service",
      "item": [
        {
          "name": "search cards",
          "request": {
            "method": "GET",
            "event": [{
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', function () { pm.response.to.have.status(200); });"] }
            }],
            "url": {
              "raw": "{{card-api}}/cards?name={{search_name}}",
              "host": ["{{card-api}}"],
              "path": ["cards"],
              "query": [{ "key": "name", "value": "{{search_name}}" }]
            }
          }
        }
      ]
    },
