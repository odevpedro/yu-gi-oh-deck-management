          "name": "create custom card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardType\": \"MONSTER\",\n  \"name\": \"Blue-Eyes Beta\",\n  \"description\": \"Sample custom monster\",\n  \"attack\": 3000,\n  \"defense\": 2500,\n  \"level\": 8,\n  \"attribute\": \"LIGHT\",\n  \"monsterType\": \"Dragon\",\n  \"summonCondition\": \"Normal Summon\"\n}"
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('card pending', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('PENDING');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{creator-api}}/custom-cards", "host": ["{{creator-api}}"], "path": ["custom-cards"] }
          }
        }
      ]
    },
    {
      "name": "proxy-service",
      "item": [
        {
          "name": "generate proxy pdf",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('pdf content type', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
                  "});"
                ]
              }
            }],
            "url": { "raw": "{{proxy-api}}/proxy/{{deck_id}}", "host": ["{{proxy-api}}"], "path": ["proxy", "{{deck_id}}"] }
          }
        }
